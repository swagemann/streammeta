# Azure DevOps connection (required)
ADO_ORG=my-org
ADO_PROJECT=my-project
ADO_REPO=my-dbt-repo
ADO_PAT=your-personal-access-token

# Optional overrides
ADO_DEFAULT_BRANCH=main
ADO_BRANCH_PREFIX=yaml-edit/

# Authentication mode: "pat" (default) or "oauth"
# Set to "oauth" for browser-based Microsoft login (no PAT needed)
AUTH_MODE=pat

# OAuth overrides (optional — sensible defaults are built in)
# AZURE_TENANT_ID=organizations
# AZURE_CLIENT_ID=04b07795-a710-4e35-9fac-d325c1e6c11c
