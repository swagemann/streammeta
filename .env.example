# Azure DevOps connection (required)
ADO_ORG=my-org
ADO_PROJECT=my-project
ADO_REPO=my-dbt-repo
ADO_PAT=your-personal-access-token

# Optional overrides
ADO_DEFAULT_BRANCH=main
ADO_BRANCH_PREFIX=yaml-edit/

# Authentication mode: "pat" (default) or "oauth"
AUTH_MODE=pat

# OAuth settings (required when AUTH_MODE=oauth)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-app-registration-client-id
# AZURE_CLIENT_SECRET=optional-for-confidential-clients
